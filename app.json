{
  "expo": {
    "name": "FRI2PLAN",
    "slug": "fri2plan-native",
    "version": "1.1.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafaf8"
    },
    "scheme": "fri2plan",
    "plugins": [
      "./plugins/withRCTTurboModulePatch",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          }
        }
      ],
      "expo-dev-client",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7c3aed",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.582461718885-4614i560felc7gquqif8v8oamod4i68s"
        }
      ],
      "./plugins/withRNSTabBarPatch",
      "expo-apple-authentication",
      "expo-calendar",
      [
        "expo-updates",
        {
          "checkAutomatically": "NEVER",
          "requestHeaders": {}
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.fri2plan.app",

      "buildNumber": "47",
      
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "NSUserNotificationsUsageDescription": "FRI2PLAN envoie des rappels et notifications pour votre famille.",
        "NSFaceIDUsageDescription": "FRI2PLAN utilise Face ID pour vous connecter rapidement et en toute sécurité.",
        "NSCalendarsUsageDescription": "FRI2PLAN accède à votre calendrier pour synchroniser vos événements familiaux.",
        "NSCalendarsFullAccessUsageDescription": "FRI2PLAN accède à votre calendrier pour synchroniser vos événements familiaux dans les deux sens.",
        "NSRemindersUsageDescription": "FRI2PLAN peut créer des rappels pour vos tâches familiales.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.applesignin": [
          "Default"
        ]
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "googleServicesFile": "./google-services.json",
      "package": "app.fri2plan.ch",
      "versionCode": 40,
      "edgeToEdgeEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "targetSdkVersion": 35,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "e57f2b3e-818f-4962-9479-6bf670caca94"
      }
    },
    "owner": "fri2plan",
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "NEVER",
      "url": "https://u.expo.dev/e57f2b3e-818f-4962-9479-6bf670caca94"
    }
  }
}
