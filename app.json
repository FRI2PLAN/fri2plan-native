{
  "expo": {
    "name": "FRI2PLAN",
    "slug": "fri2plan-native",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "scheme": "fri2plan",
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/app",
      "./withFirebasePodfile",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.846470017457-b250hpecqp44u8av020p72f87dch0dus"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.fri2plan.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.fri2plan.app",
      "versionCode": 3,
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "e57f2b3e-818f-4962-9479-6bf670caca94"
      }
    },
    "owner": "fri2plan",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e57f2b3e-818f-4962-9479-6bf670caca94",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
